{
    "version": 2,
    "builds": [
      {
        "src": "api/index.js",
        "use": "@vercel/node"
      }
    ],
    "routes": [
      {
        "src": "/api/(.*)",
        "dest": "/api/index.js"
      },
      {
        "src": "/health",
        "dest": "/api/index.js"
      },
      {
        "src": "/styles.css",
        "dest": "/frontend/styles.css"
      },
      {
        "src": "/",
        "dest": "/frontend/index.html"
      },
      {
        "src": "/(.*)",
        "dest": "/frontend/index.html"
      }
    ]
  }
