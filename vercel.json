{
    "functions": {
      "api/*.js": {
        "runtime": "@vercel/node@3"
      }
    },
    "routes": [
      {
        "src": "/health",
        "dest": "/api/health"
      },
      {
        "src": "/api/(.*)",
        "dest": "/api/$1"
      },
      {
        "src": "/styles.css",
        "dest": "/frontend/styles.css"
      },
      {
        "src": "/",
        "dest": "/frontend/index.html"
      }
    ]
  }
